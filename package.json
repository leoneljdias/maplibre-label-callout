{
  "name": "@leoneljdias/maplibre-label-callout",
  "version": "1.1.1",
  "description": "Labels with connector lines for MapLibre GL JS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "maplibre-gl": ">=3"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rollup": "^4"
  },
  "scripts": {
    "build": "rollup -c",
    "format": "prettier --write src/ demo/ *.md *.json",
    "format:check": "prettier --check src/ demo/ *.md *.json",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md,html}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leoneljdias/maplibre-label-callout.git"
  },
  "homepage": "https://leoneljdias.github.io/maplibre-label-callout/demo/",
  "bugs": {
    "url": "https://github.com/leoneljdias/maplibre-label-callout/issues"
  },
  "keywords": [
    "maplibre",
    "maplibre-gl",
    "label",
    "callout",
    "connector-line"
  ],
  "license": "MIT"
}
